# Edge Backup Railway — copy to .env for local overrides (optional)

# Catcher API (clients, scripts, Playwright API tests)
CATCHER_URL=http://127.0.0.1:8000

# Backend: retention in seconds when set to 1, true, or yes
DEMO_MODE=

# Backend listen port (run-backend.sh)
PORT=8000

# Docker client
WATCH_DIR=.
SOURCE_ID=docker-client
POLL_INTERVAL=5

# Frontend dev proxy target (container dashboard uses http://catcher:8000)
VITE_PROXY_API=http://127.0.0.1:8000

# Restic client (compose stack)
RESTIC_REPOSITORY=s3:http://minio:9000/restic
RESTIC_PASSWORD=restic-demo
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
BACKUP_INTERVAL=60

# Playwright
BASE_URL=http://127.0.0.1:5173

# Container runtime: podman or docker (auto-detected if unset)
# CONTAINER_RUNTIME=podman
