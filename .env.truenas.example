# TrueNAS deployment environment
# Copy to .env.truenas and adjust for your NAS

# Host path mapped to catcher persistence (use a ZFS dataset on TrueNAS)
TRUENAS_DATA_PATH=./data/truenas

# Published ports on the NAS
CATCHER_PORT=8000
DASHBOARD_PORT=8080

# CORS: set to your LAN dashboard origin(s) in production
CORS_ORIGINS=*

LOG_LEVEL=INFO
EBK_AI_STATUS=0

# Optional observability (enable profile: observability)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_GRPC_PORT=4317
# OTEL_HTTP_PORT=4318
